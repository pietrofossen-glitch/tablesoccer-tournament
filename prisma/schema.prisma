// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Match {
  id                Int               @id @default(autoincrement())
  createdAt         DateTime          @default(now())
  team1             String
  team2             String
  score1            Int
  score2            Int
  team1RatingChange Float             @default(0)
  team2RatingChange Float             @default(0)
  team1Rating       Float             @default(0)
  team2Rating       Float             @default(0)
  comment           String
  game              String
  teamsize          Int
  season            Int               @default(1)
  achievements      TeamAchievement[]
  players           MatchPlayer[]

  @@index(season)
  @@map("match")
}

model Team {
  id           Int               @id @default(autoincrement())
  createdAt    DateTime          @default(now())
  name         String
  teamsize     Int
  meta         TeamMeta[]
  achievements TeamAchievement[]

  @@unique(name)
  @@map("team")
}

model TeamMeta {
  id                       Int      @id @default(autoincrement())
  createdAt                DateTime @default(now())
  team                     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  season                   Int      @default(1)
  teamId                   Int
  rating                   Float    @default(0)
  achievementPoints        Int      @default(0)
  totalMatches             Int      @default(0)
  totalWins                Int      @default(0)
  totalLosses              Int      @default(0)
  totalWinRate             Float    @default(0)
  totalScore               Int      @default(0)
  totalAvgScore            Float    @default(0)
  totalHighestRating       Float    @default(0)
  totalLowestRating        Float    @default(0)
  totalHighestWinStreak    Int      @default(0)
  totalHighestLosingStreak Int      @default(0)
  dailyMatches             Int      @default(0)
  dailyWins                Int      @default(0)
  dailyLosses              Int      @default(0)
  dailyWinRate             Float    @default(0)
  dailyScore               Int      @default(0)
  dailyAvgScore            Float    @default(0)
  currentWinStreak         Int      @default(0)
  currentLosingStreak      Int      @default(0)
  updatedAt                DateTime @default(now())

  @@unique([season, teamId])
  @@index([teamId, season])
  @@map("team_meta")
}

model TeamAchievement {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamName    String
  teamId      Int
  achievement String
  season      Int      @default(1)
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId     Int

  @@index([matchId, teamId])
  @@map("team_achievement")
}

model Season {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  number    Int      @unique
  current   Boolean  @default(false)

  @@index(number)
  @@map("season")
}

model Player {
  id        Int           @id @default(autoincrement())
  createdAt DateTime      @default(now())
  name      String        @unique
  meta      PlayerMeta[]
  matches   MatchPlayer[]

  @@map("player")
}

model PlayerMeta {
  id                       Int      @id @default(autoincrement())
  createdAt                DateTime @default(now())
  player                   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  season                   Int      @default(1)
  playerId                 Int
  rating                   Float    @default(0)
  totalMatches             Int      @default(0)
  totalWins                Int      @default(0)
  totalLosses              Int      @default(0)
  totalWinRate             Float    @default(0)
  totalScore               Int      @default(0)
  totalAvgScore            Float    @default(0)
  totalHighestRating       Float    @default(0)
  totalLowestRating        Float    @default(0)
  totalHighestWinStreak    Int      @default(0)
  totalHighestLosingStreak Int      @default(0)
  dailyMatches             Int      @default(0)
  dailyWins                Int      @default(0)
  dailyLosses              Int      @default(0)
  dailyWinRate             Float    @default(0)
  dailyScore               Int      @default(0)
  dailyAvgScore            Float    @default(0)
  currentWinStreak         Int      @default(0)
  currentLosingStreak      Int      @default(0)
  updatedAt                DateTime @default(now())

  @@unique([season, playerId])
  @@index([playerId, season])
  @@map("player_meta")
}

model MatchPlayer {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId      Int
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId     Int
  teamSide     Int
  season       Int      @default(1)
  ratingBefore Float    @default(0)
  ratingAfter  Float    @default(0)
  ratingChange Float    @default(0)

  @@index([matchId, playerId])
  @@index([playerId, season])
  @@map("match_player")
}
